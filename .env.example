# Copy to .env and fill in. Do not commit .env.

# Anthropic API key (required).
ANTHROPIC_API_KEY=

# Optional: answering model. Defaults to claude-haiku-4-5 (small by design — see
# docs/rationale.md).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: judge model for --judge / --summary. Defaults to claude-opus-4-8.
# ANTHROPIC_JUDGE_MODEL=claude-opus-4-8

# Optional: max output tokens. Defaults to 1024.
# ANTHROPIC_MAX_TOKENS=1024

# Optional: sampling temperature. Only sent to the API when set, and only to the
# answering model. NOTE: claude-opus-4-8 (and the 4.7 / Fable families) reject
# `temperature` with a 400 error. Set this only with a model that accepts
# sampling parameters (e.g. claude-haiku-4-5, claude-sonnet-4-6).
# ANTHROPIC_TEMPERATURE=1.0
