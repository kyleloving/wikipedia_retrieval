# Copy to .env and fill in. Do not commit .env.

# Anthropic API key (required).
ANTHROPIC_API_KEY=

# Optional: model id. Defaults to claude-opus-4-8.
# ANTHROPIC_MODEL=claude-opus-4-8

# Optional: max output tokens. Defaults to 1024.
# ANTHROPIC_MAX_TOKENS=1024

# Optional: sampling temperature. Only sent to the API when set.
# NOTE: the default model claude-opus-4-8 (and the 4.7 / Fable families) reject
# `temperature` with a 400 error. Set this only with a model that accepts
# sampling parameters (e.g. claude-sonnet-4-5, claude-haiku-4-5).
# ANTHROPIC_TEMPERATURE=1.0
